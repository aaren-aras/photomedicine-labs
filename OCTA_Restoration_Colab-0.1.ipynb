   "source": [
    "# OCTA Image Restoration — ResU-Net\n",
    "**Task:** Reconstruct high-quality OCTA images from sparsely acquired (degraded) inputs.\n",
    "\n",
    "**Architecture grounded in:**\n",
    "- Liao et al. (IRU-Net, *Biomed. Opt. Express* 2023) — L2 + VGG19 content loss, dense residual blocks\n",
    "- Das et al. (RRTGAN, *npj AI* 2025) — sparse-to-dense restoration framework for retinal imaging\n",
    "\n",
    "**Training pairs:** Clean OCTA images (ground truth) + on-the-fly simulated degradation (input)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 1. Check GPU ──────────────────────────────────────────────────────────────\n",
    "import tensorflow as tf\n",
    "print('TF version:', tf.__version__)\n",
    "print('GPU devices:', tf.config.list_physical_devices('GPU'))\n",
    "\n",
    "gpus = tf.config.list_physical_devices('GPU')\n",
    "if gpus:\n",
    "    tf.config.experimental.set_memory_growth(gpus[0], True)\n",
    "    print('✓ GPU memory growth enabled')\n",
    "else:\n",
    "    print('⚠ No GPU found — go to Runtime > Change runtime type > T4 GPU')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 2. Upload & unzip your preprocessed OCTA-500 data ────────────────────────\n",
    "# Zip your local data folder first:\n",
    "#   data/OCTA-500_processed/images/train/*.npy\n",
    "#   data/OCTA-500_processed/images/valid/*.npy\n",
    "# Then upload the zip here.\n",
    "\n",
    "from google.colab import files\n",
    "import zipfile, os\n",
    "\n",
    "print('Upload your zipped data folder (e.g. octa_data.zip):')\n",
    "uploaded = files.upload()  # triggers file picker\n",
    "\n",
    "zip_name = list(uploaded.keys())[0]\n",
    "with zipfile.ZipFile(zip_name, 'r') as z:\n",
    "    z.extractall('/content/data')\n",
    "    \n",
    "print('Extracted files:')\n",
    "for root, dirs, files_ in os.walk('/content/data'):\n",
    "    for f in files_[:5]:  # show first 5\n",
    "        print(' ', os.path.join(root, f))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 3. Config — adjust paths & hyperparameters here ──────────────────────────\n",
    "from pathlib import Path\n",
    "\n",
    "IMG_TRAIN_DIR = Path('/content/data/OCTA-500_processed/images/train')\n",
    "IMG_VALID_DIR = Path('/content/data/OCTA-500_processed/images/valid')\n",
    "MODELS_DIR    = Path('/content/models')\n",
    "MODELS_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "# ── Verify data exists ──\n",
    "train_files = sorted(IMG_TRAIN_DIR.iterdir())\n",
    "valid_files = sorted(IMG_VALID_DIR.iterdir())\n",
    "print(f'Train images: {len(train_files)}')\n",
    "print(f'Valid images: {len(valid_files)}')\n",
    "\n",
    "# ── Check image shape ──\n",
    "import numpy as np\n",
    "sample = np.load(train_files[0])\n",
    "print(f'Sample shape: {sample.shape}, dtype: {sample.dtype}, range: [{sample.min()}, {sample.max()}]')\n",
    "\n",
    "# ↓ Set this to match your actual image dimensions\n",
    "IMG_H, IMG_W = sample.shape[0], sample.shape[1]\n",
    "IMG_SIZE = (IMG_H, IMG_W)\n",
    "print(f'\\nUsing IMG_SIZE = {IMG_SIZE}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 4. Hyperparameters ────────────────────────────────────────────────────────\n",
    "FILTERS        = [32, 64, 128, 256]\n",
    "KERNEL_SIZE    = 3\n",
    "SCALE_FACTOR   = 2\n",
    "DROPOUT_RATE   = 0.3\n",
    "LEARNING_RATE  = 1e-4\n",
    "BATCH_SIZE     = 4      # increase to 8 if you have >8GB VRAM\n",
    "EPOCHS         = 50     # EarlyStopping will cut this short if val_loss plateaus\n",
    "CONTENT_WEIGHT = 0.01   # β from Liao et al. — optimal value from their ablation study"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 5. Metrics ────────────────────────────────────────────────────────────────\n",
    "class PSNRMetric(tf.keras.metrics.Metric):\n",
    "    \"\"\"Peak Signal-to-Noise Ratio — higher is better (dB).\"\"\"\n",
    "    def __init__(self, name='psnr', **kwargs):\n",
    "        super().__init__(name=name, **kwargs)\n",
    "        self.psnr_sum = self.add_weight('psnr_sum', initializer='zeros')\n",
    "        self.count    = self.add_weight('count',    initializer='zeros')\n",
    "    def update_state(self, y_true, y_pred, sample_weight=None):\n",
    "        psnr = tf.image.psnr(y_true, y_pred, max_val=1.0)\n",
    "        self.psnr_sum.assign_add(tf.reduce_sum(psnr))\n",
    "        self.count.assign_add(tf.cast(tf.shape(y_true)[0], tf.float32))\n",
    "    def result(self): return self.psnr_sum / self.count\n",
    "    def reset_states(self): self.psnr_sum.assign(0.); self.count.assign(0.)\n",
    "\n",
    "class SSIMMetric(tf.keras.metrics.Metric):\n",
    "    \"\"\"Structural Similarity Index — 0 to 1, higher is better.\"\"\"\n",
    "    def __init__(self, name='ssim', **kwargs):\n",
    "        super().__init__(name=name, **kwargs)\n",
    "        self.ssim_sum = self.add_weight('ssim_sum', initializer='zeros')\n",
    "        self.count    = self.add_weight('count',    initializer='zeros')\n",
    "    def update_state(self, y_true, y_pred, sample_weight=None):\n",
    "        ssim = tf.image.ssim(y_true, y_pred, max_val=1.0)\n",
    "        self.ssim_sum.assign_add(tf.reduce_sum(ssim))\n",
    "        self.count.assign_add(tf.cast(tf.shape(y_true)[0], tf.float32))\n",
    "    def result(self): return self.ssim_sum / self.count\n",
    "    def reset_states(self): self.ssim_sum.assign(0.); self.count.assign(0.)\n",
    "\n",
    "print('✓ Metrics defined')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 6. Loss Function ──────────────────────────────────────────────────────────\n",
    "from tensorflow.keras.applications import VGG19\n",
    "from tensorflow.keras import Model\n",
    "\n",
    "# Build VGG feature extractor once\n",
    "vgg_base = VGG19(include_top=False, weights='imagenet',\n",
    "                 input_shape=(*IMG_SIZE, 3))\n",
    "vgg_base.trainable = False\n",
    "vgg_extractor = Model(inputs=vgg_base.input,\n",
    "                      outputs=vgg_base.get_layer('block5_conv4').output)\n",
    "print('✓ VGG19 feature extractor ready (block5_conv4)')\n",
    "\n",
    "def content_loss(y_true, y_pred):\n",
    "    \"\"\"MSE between VGG19 deep features — preserves vascular texture.\"\"\"\n",
    "    y_true_rgb = tf.repeat(y_true, 3, axis=-1) * 255.0\n",
    "    y_pred_rgb = tf.repeat(y_pred, 3, axis=-1) * 255.0\n",
    "    return tf.reduce_mean(tf.square(\n",
    "        vgg_extractor(y_true_rgb, training=False) -\n",
    "        vgg_extractor(y_pred_rgb, training=False)\n",
    "    ))\n",
    "\n",
    "def restoration_loss(y_true, y_pred):\n",
    "    \"\"\"L2 + 0.01 * content_loss  (Liao et al. 2023 optimal configuration).\"\"\"\n",
    "    return tf.reduce_mean(tf.square(y_true - y_pred)) + CONTENT_WEIGHT * content_loss(y_true, y_pred)\n",
    "\n",
    "print('✓ Restoration loss ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 7. Model Architecture ─────────────────────────────────────────────────────\n",
    "from tensorflow.keras import layers\n",
    "from tensorflow.keras.regularizers import l2 as l2_reg\n",
    "from tensorflow.keras.optimizers import Adam\n",
    "\n",
    "def residual_dense_block(x, filters, kernel_size=KERNEL_SIZE):\n",
    "    \"\"\"Residual block with dense connection + LeakyReLU (no BatchNorm).\"\"\"\n",
    "    shortcut = x\n",
    "    h1 = layers.Conv2D(filters, kernel_size, padding='same',\n",
    "                        kernel_regularizer=l2_reg(1e-4))(x)\n",
    "    h1 = layers.LeakyReLU(0.2)(h1)\n",
    "    h2_in = layers.Concatenate()([x, h1]) if x.shape[-1] == filters else h1\n",
    "    h2 = layers.Conv2D(filters, kernel_size, padding='same',\n",
    "                        kernel_regularizer=l2_reg(1e-4))(h2_in)\n",
    "    h2 = layers.LeakyReLU(0.2)(h2)\n",
    "    if shortcut.shape[-1] != filters:\n",
    "        shortcut = layers.Conv2D(filters, 1, padding='same')(shortcut)\n",
    "    return layers.Add()([shortcut, h2])\n",
    "\n",
    "def build_restoration_model(input_shape=(*IMG_SIZE, 1)):\n",
    "    inp = tf.keras.Input(shape=input_shape)\n",
    "    # Encoder\n",
    "    c1 = residual_dense_block(layers.Conv2D(FILTERS[0], KERNEL_SIZE, padding='same')(inp), FILTERS[0])\n",
    "    p1 = layers.MaxPooling2D(SCALE_FACTOR)(c1)\n",
    "    c2 = residual_dense_block(layers.Conv2D(FILTERS[1], KERNEL_SIZE, padding='same')(p1), FILTERS[1])\n",
    "    p2 = layers.MaxPooling2D(SCALE_FACTOR)(c2)\n",
    "    c3 = residual_dense_block(layers.Conv2D(FILTERS[2], KERNEL_SIZE, padding='same')(p2), FILTERS[2])\n",
    "    p3 = layers.MaxPooling2D(SCALE_FACTOR)(c3)\n",
    "    # Bottleneck\n",
    "    b  = residual_dense_block(layers.Conv2D(FILTERS[3], KERNEL_SIZE, padding='same')(p3), FILTERS[3])\n",
    "    b  = layers.Dropout(DROPOUT_RATE)(b)\n",
    "    # Decoder\n",
    "    u3 = layers.Dropout(0.15)(layers.UpSampling2D(SCALE_FACTOR)(b))\n",
    "    c4 = residual_dense_block(layers.Concatenate()([u3, c3]), FILTERS[2])\n",
    "    u2 = layers.Dropout(0.15)(layers.UpSampling2D(SCALE_FACTOR)(c4))\n",
    "    c5 = residual_dense_block(layers.Concatenate()([u2, c2]), FILTERS[1])\n",
    "    u1 = layers.Dropout(0.15)(layers.UpSampling2D(SCALE_FACTOR)(c5))\n",
    "    c6 = residual_dense_block(layers.Concatenate()([u1, c1]), FILTERS[0])\n",
    "    # Output\n",
    "    out = layers.Conv2D(1, kernel_size=1, activation='sigmoid', name='restoration')(c6)\n",
    "    model = Model(inputs=inp, outputs=out)\n",
    "    model.compile(\n",
    "        optimizer=Adam(learning_rate=LEARNING_RATE, beta_1=0.8, beta_2=0.999),\n",
    "        loss=restoration_loss,\n",
    "        metrics=[PSNRMetric(), SSIMMetric()]\n",
    "    )\n",
    "    return model\n",
    "\n",
    "model = build_restoration_model()\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 8. Data Generator with On-the-fly Degradation ────────────────────────────\n",
    "\n",
    "def simulate_sparse_acquisition(clean, severity=0.3):\n",
    "    \"\"\"\n",
    "    Simulate low-repeat OCTA acquisition noise (Liao et al. 2023):\n",
    "    1. Shot noise (Poisson-like)\n",
    "    2. B-scan line dropout (motion between repeat acquisitions)\n",
    "    3. Multiplicative speckle noise\n",
    "    \"\"\"\n",
    "    img = clean.squeeze()\n",
    "    H, W = img.shape\n",
    "    # Shot noise\n",
    "    shot = np.random.normal(0, 1, img.shape).astype(np.float32) * severity * 0.3 * np.sqrt(img + 1e-6)\n",
    "    noisy = img + shot\n",
    "    # B-scan dropout\n",
    "    for line in np.random.choice(H, int(H * severity * 0.4), replace=False):\n",
    "        noisy[line, :] = noisy[max(0, line-1), :] * 0.4\n",
    "    # Speckle\n",
    "    noisy = noisy * (1.0 + np.random.rayleigh(severity * 0.2, img.shape).astype(np.float32))\n",
    "    return np.expand_dims(np.clip(noisy, 0.0, 1.0), axis=-1)\n",
    "\n",
    "def restoration_generator(img_dir, augment=False, batch_size=BATCH_SIZE,\n",
    "                           severity_range=(0.15, 0.40)):\n",
    "    img_files = sorted(img_dir.iterdir())\n",
    "    n = len(img_files)\n",
    "    while True:\n",
    "        idx = np.arange(n)\n",
    "        if augment: np.random.shuffle(idx)\n",
    "        for i in range(0, n, batch_size):\n",
    "            batch_clean, batch_deg = [], []\n",
    "            for j in idx[i:min(i+batch_size, n)]:\n",
    "                raw = np.load(img_files[j])\n",
    "                clean = raw.astype(np.float32)\n",
    "                if clean.max() > 1.0: clean /= 255.0\n",
    "                if clean.ndim == 2: clean = np.expand_dims(clean, -1)\n",
    "                if augment:\n",
    "                    if np.random.rand() > 0.5: clean = np.fliplr(clean)\n",
    "                    if np.random.rand() > 0.5: clean = np.flipud(clean)\n",
    "                severity = np.random.uniform(*severity_range)\n",
    "                batch_clean.append(clean)\n",
    "                batch_deg.append(simulate_sparse_acquisition(clean, severity))\n",
    "            yield np.array(batch_deg), np.array(batch_clean)  # input, target\n",
    "\n",
    "# Quick sanity check\n",
    "import matplotlib.pyplot as plt\n",
    "gen = restoration_generator(IMG_TRAIN_DIR, augment=False, batch_size=1)\n",
    "deg_sample, clean_sample = next(gen)\n",
    "fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n",
    "axes[0].imshow(deg_sample[0, :, :, 0], cmap='gray'); axes[0].set_title('Degraded (input)')\n",
    "axes[1].imshow(clean_sample[0, :, :, 0], cmap='gray'); axes[1].set_title('Clean (target)')\n",
    "plt.suptitle('Sanity Check — training pair'); plt.tight_layout(); plt.show()\n",
    "print(f'Degraded range: [{deg_sample.min():.3f}, {deg_sample.max():.3f}]')\n",
    "print(f'Clean range:    [{clean_sample.min():.3f}, {clean_sample.max():.3f}]')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 9. Train ──────────────────────────────────────────────────────────────────\n",
    "from tensorflow.keras.callbacks import EarlyStopping, ModelCheckpoint, TensorBoard\n",
    "\n",
    "train_gen   = restoration_generator(IMG_TRAIN_DIR, augment=True)\n",
    "valid_gen   = restoration_generator(IMG_VALID_DIR, augment=False)\n",
    "train_steps = len(list(IMG_TRAIN_DIR.iterdir())) // BATCH_SIZE\n",
    "valid_steps = len(list(IMG_VALID_DIR.iterdir())) // BATCH_SIZE\n",
    "\n",
    "print(f'Train steps/epoch: {train_steps}')\n",
    "print(f'Valid steps/epoch: {valid_steps}')\n",
    "\n",
    "callbacks = [\n",
    "    EarlyStopping(monitor='val_loss', patience=10,\n",
    "                  restore_best_weights=True, verbose=1),\n",
    "    ModelCheckpoint(str(MODELS_DIR / 'best_model.keras'),\n",
    "                    monitor='val_psnr', mode='max',\n",
    "                    save_best_only=True, verbose=1),\n",
    "]\n",
    "\n",
    "history = model.fit(\n",
    "    train_gen,\n",
    "    steps_per_epoch=train_steps,\n",
    "    validation_data=valid_gen,\n",
    "    validation_steps=valid_steps,\n",
    "    epochs=EPOCHS,\n",
    "    callbacks=callbacks,\n",
    "    verbose=1\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
