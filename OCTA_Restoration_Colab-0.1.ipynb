    "# ── 11. Visual Results on Validation Set ─────────────────────────────────────\n",
    "val_files = sorted(IMG_VALID_DIR.iterdir())\n",
    "n_show = min(4, len(val_files))\n",
    "fig, axes = plt.subplots(n_show, 3, figsize=(12, 4 * n_show))\n",
    "\n",
    "for i in range(n_show):\n",
    "    raw = np.load(val_files[i]).astype(np.float32)\n",
    "    if raw.max() > 1.0: raw /= 255.0\n",
    "    if raw.ndim == 2: raw = np.expand_dims(raw, -1)\n",
    "    clean = raw\n",
    "    degraded = simulate_sparse_acquisition(clean, severity=0.3)\n",
    "    restored = model.predict(degraded[np.newaxis])[0]\n",
    "\n",
    "    psnr_in  = tf.image.psnr(clean[np.newaxis], degraded[np.newaxis], max_val=1.0).numpy()[0]\n",
    "    psnr_out = tf.image.psnr(clean[np.newaxis], restored[np.newaxis], max_val=1.0).numpy()[0]\n",
    "\n",
    "    axes[i][0].imshow(degraded[:,:,0], cmap='gray')\n",
    "    axes[i][0].set_title(f'Degraded\\nPSNR: {psnr_in:.1f} dB')\n",
    "    axes[i][1].imshow(restored[:,:,0], cmap='gray')\n",
    "    axes[i][1].set_title(f'Restored\\nPSNR: {psnr_out:.1f} dB')\n",
    "    axes[i][2].imshow(clean[:,:,0], cmap='gray')\n",
    "    axes[i][2].set_title('Ground Truth')\n",
    "    for ax in axes[i]: ax.axis('off')\n",
    "\n",
    "plt.suptitle('Validation Results: Degraded → Restored → Ground Truth', fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.savefig(str(MODELS_DIR / 'validation_results.png'), dpi=150)\n",
    "plt.show()"
   ]
