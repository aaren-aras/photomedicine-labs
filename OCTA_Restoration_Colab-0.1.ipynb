   "source": [
    "# ── 10. Plot Training Curves ──────────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
    "\n",
    "axes[0].plot(history.history['loss'], label='train')\n",
    "axes[0].plot(history.history['val_loss'], label='val')\n",
    "axes[0].set_title('Loss (L2 + Content)'); axes[0].legend()\n",
    "\n",
    "axes[1].plot(history.history['psnr'], label='train')\n",
    "axes[1].plot(history.history['val_psnr'], label='val')\n",
    "axes[1].set_title('PSNR (dB) ↑ better'); axes[1].legend()\n",
    "\n",
    "axes[2].plot(history.history['ssim'], label='train')\n",
    "axes[2].plot(history.history['val_ssim'], label='val')\n",
    "axes[2].set_title('SSIM ↑ better'); axes[2].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(str(MODELS_DIR / 'training_curves.png'), dpi=150)\n",
    "plt.show()"
   ]
  },
